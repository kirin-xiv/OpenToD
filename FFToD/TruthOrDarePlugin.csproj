        <AssemblyVersion>$(Version)</AssemblyVersion>
        <FileVersion>$(Version)</FileVersion>
        <Authors>Kirin Avenleigh</Authors>
        <Description>Truth or Dare mini-game automation plugin for FFXIV</Description>
        <PackageProjectUrl>https://github.com/kirin-xiv/FFToD-Release</PackageProjectUrl>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <IsPackable>false</IsPackable>
        <DalamudApiLevel>14</DalamudApiLevel>
